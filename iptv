/* =========================================================
   🔹 ৬. parse(data)
   ➜ M3U হলে #EXTINF থেকে নাম + লিঙ্ক
   ➜ না হলে regex দিয়ে ভিডিও লিঙ্ক খোঁজে
   ========================================================= */
function parse(data) {
  let results = [];

  if (data.includes('#EXTINF')) {
    const lines = data.split('\n');
    for (let i = 0; i < lines.length; i++) {
      if (lines[i].includes('#EXTINF')) {
        let name = lines[i].split(',').pop().trim();
        let url = lines[i + 1] ? lines[i + 1].trim() : "";
        if (url.startsWith('http')) results.push({ name: name, url: url });
      }
    }
  } else {
    const regex = /(?:name|title|ch)="([^"]+)"[\s\S]*?(https?:\/\/[^\s<>"]+\.(?:m3u8|mp4|ts|php|mkv|embed))/gi;
    let match;
    while ((match = regex.exec(data)) !== null) {
      results.push({ name: match[1], url: match[2] });
    }
  }

  return results;
}


