    `;

    document.body.appendChild(overlay);

    // Button actions
    document.getElementById('openChromeBtn').onclick = function(e) {
        e.stopPropagation();
        forceRedirect();
    };

    document.getElementById('closeOverlay').onclick = function() {
        overlay.style.display = 'none';
