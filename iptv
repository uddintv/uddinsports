/* ===============================
   Channel Overlay
   ভিডিওর উপর চ্যানেলের নাম দেখানোর স্টাইল
   =============================== */
.channel-display-overlay {
    position: absolute;
    bottom: 30px; 
    left: 50%; 
    transform: translateX(-50%);
    color: yellow;
    padding: 4px ;
   /*  font-weight: bold;*/
    font-size: 18px;
    z-index: 999;
    display: none; 
    pointer-events: none;
    animation: fadeInOut 4s forwards;
  /* নিচের এই ৩টি লাইন যোগ করুন */
    white-space: nowrap;       /* টেক্সটকে ২য় লাইনে যেতে বাধা দেবে */
    overflow: hidden;          /* অতিরিক্ত অংশ লুকিয়ে ফেলবে */

  
}

@keyframes fadeInOut {
    0% { opacity: 0; }   
    10% { opacity: 1; }  
    80% { opacity: 1; }  
    100% { opacity: 0; } 
 }
  
        
/* ===============================
   In-Video Overlay Controls
   =============================== */
.video-overlay {
    position: absolute;
    inset: 0;
    z-index: 1000;
    pointer-events: none;
    transition: opacity .3s;
}

.video-overlay.hidden { opacity: 0; }
.video-overlay:not(.hidden) { opacity: 1; }

/* সব বাটন clickable */
.video-overlay button,
.overlay-ch,
.overlay-ch-nav {
    pointer-events: auto;
}

/* NEXT / PREV   */
.overlay-nav {
    position: absolute;
    top: 50%;
    transform: translateY(-50%);
    background:  rgba(255, 255, 255, 0.1); /*  rgba(0,0,0,.0); */
    color: green ;/*yellow  rgba(255, 255, 0,0.1)*/
    font-size: 20px; /* 24px  */
    padding: 13px 8px; /*   5% 14px; */
    /*border-radius: 50%; */
  border: 1px solid rgba(255, 255, 255, 0.3); /*  none; */
  border-radius: 10px;
  backdrop-filter: blur(4px);
  
    cursor: pointer;
    transition: 0.3s;
}
/* #playerBox.mouse-active .overlay-nav { font-size: 38px;color:#fff;background: rgba(0,0,0,.1);}   */
#playerBox.mouse-active .overlay-nav { color:lime ;} 
.overlay-nav:hover{ font-size: 24px;}
      
.overlay-nav.left { left: 0px; } /* 0px  */
.overlay-nav.right { right: 0px; } /*  0px */

    
/* FULLSCREEN */
.overlay-fullscreen {
    position: absolute;
    bottom: 0;
    right: 0;
    background:rgba(0, 0, 0, 0.7);  /* rgba(0,0,0,1);  */
    color: #fff; /* rgba(255, 255, 0, 0.7);  yellow */
    border: none;
    font-size: 22px; /*  22px; */
    padding: 5px 12px;
    border-radius: 50%;
    cursor: pointer;
    /* opacity: 0.2 !important; সব সময় হালকা থাকবে */
    display: flex !important; /* hidden ক্লাস থাকলেও যেন ব্লক না হয় */
}
 .overlay-fullscreen:hover{background: rgba(0,0,0,0.7);transform:scale(1.5);}   
