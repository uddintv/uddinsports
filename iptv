/* ২. আইফ্রেম (ভিডিও) এর ভেতরে countdown */
function nuCount(seconds) {
    let count = seconds;
    const display = document.getElementById('video-countdown');
    if (!display) return;

    display.style.display = 'block';
    display.innerText = count;

    // যদি আগে থেকে কোনো টাইমার চলে সেটা বন্ধ করতে হবে (নিরাপত্তার জন্য)
    if (window.currentTimer) clearInterval(window.currentTimer);

    window.currentTimer = setInterval(() => {
        count--;
        if (count >= 1) {
            display.innerText = count;
        } else {
            clearInterval(window.currentTimer);
            display.style.display = 'none';
        }
    }, 1000);
}
</script>



