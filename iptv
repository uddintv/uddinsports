    // নাম বা নাম + :সংখ্যা (যেমন: Somoy TV:1)
    let refName = clean;
    let selectedNumbers = null;

    if (clean.includes(":")) {
      const parts = clean.split(":");
      refName = parts[0].trim();
      selectedNumbers = parts[1].match(/\d+/g)?.map(n => parseInt(n));
    }

    let refList = allData.filter(ch =>
      ch.name.toLowerCase().replace(/\s/g, '')
        .includes(refName.toLowerCase().replace(/\s/g, ''))
    );

    // ডোমেইন অনুযায়ী ইউনিক লিস্ট তৈরি
    let domainFilteredList = [];
    let tempDomains = new Set();
    refList.forEach(r => {
      try {
        const dom = new URL(r.url).hostname;
        if (!tempDomains.has(dom)) {
          tempDomains.add(dom);
          domainFilteredList.push(r);
        }
      } catch(e) { domainFilteredList.push(r); }
    });

    // ম্যাচে পুশ করা
    const addToMatches = (r) => {
      matches.push({
        name: chName,
        url: r.url,
        sandbox: "none",
        source: "manual-ref",
        manualItem: item
        
      });
      try { manualSeenDomains.add(new URL(r.url).hostname); } catch(e){}
    };

    if (selectedNumbers && selectedNumbers.length) {
      selectedNumbers.forEach(n => {
        if (domainFilteredList[n - 1]) addToMatches(domainFilteredList[n - 1]);
      });
    } else {
      domainFilteredList.forEach(r => addToMatches(r));
    }
  });
}

