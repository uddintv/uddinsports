  // ইনপুট বা textarea এ টাইপ করলে কাজ করবে না
  const tag = document.activeElement.tagName.toLowerCase();
  if (tag === "input" || tag === "textarea") return;

  // 👉 Right Arrow = Next
  if (e.key === "ArrowRight" ) {
    e.preventDefault();
    //changeCh(1);   ....NEXT CHANNEL
    goToNextServer(); //NEXT SERVER
  }

  // 👈 Left Arrow = Previous
  if (e.key === "ArrowLeft" ) {
    e.preventDefault();
    //changeCh(-1);  ... PREVIOUS CHANNEL
    goToPrevServer();   //PREVIOUS SERVER
  }
// F চাপলে
  if (e.key === "f" || e.key === "F" || e.key === "v" || e.key === "V" ) {
    e.preventDefault();
    toggleFullscreen();
  }    

      // check for Space key
    if (e.code === "Space" || e.keyCode === 32) {
        e.preventDefault(); // page scroll block
        if (video.paused) {
            video.play();
        } else {
            video.pause();
        }
    }
  // Enter চাপলে
  if (e.key === "Enter") {
 e.preventDefault(); // page scroll block
        if (video.paused) {
            video.play();
        } else {
            video.pause();
        }
    }
  
    // 🔊 Volume Up / Down
  if (e.key === "ArrowUp") { 
      e.preventDefault();
      video.volume = Math.min(video.volume + 0.1, 1); // max 1
  }
  if (e.key === "ArrowDown") { 
      e.preventDefault();
      video.volume = Math.max(video.volume - 0.1, 0); // min 0
  }

  // 🔇 M key toggle mute
  if (e.key === "m" || e.key === "M") {
      e.preventDefault();
      video.muted = !video.muted;
  }
  
});

