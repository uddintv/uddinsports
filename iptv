function showUnmuteTextIfPhp(url) {

  // টেক্সট (bottom-right) এবং কাউন্টডাউন (center) এলিমেন্ট ধরা
  //const text = document.getElementById("unmute-text-anim");
  const countEl = document.getElementById("unmute-count");

  // যদি কোনো এলিমেন্ট না পাওয়া যায়, তাহলে function বন্ধ
 // if (!text || !countEl) return;
  if ( !countEl) return;

  
  
  // শুধু .php URL হলে কাজ করবে
  if (!url.toLowerCase().includes(".php")) return;

  // কাউন্টডাউনের শুরুর মান (৭ সেকেন্ড)
  let count = 7;
  countEl.innerText = count;

  // আগের animation reset করা
  //text.style.animation = "none";
  countEl.style.animation = "none";

  // reflow trigger (animation আবার চালানোর জন্য)
  //void text.offsetWidth;
  void countEl.offsetWidth;

  // নতুন করে fadeInOut animation চালু
  //text.style.animation = "fadeInOut 1s forwards";   // ⬅️ 7 সেকেন্ড text
  countEl.style.animation = "fadeInOut 7s forwards";   // ⬅️ 7 সেকেন্ড number

  // টেক্সট ও নাম্বার দুটোই দেখানো
  //text.style.display = "block";
  countEl.style.display = "block";

  // প্রতি ১ সেকেন্ডে কাউন্টডাউন কমানো
  const interval = setInterval(() => {
    count--;

    // কাউন্ট ০ হলে interval বন্ধ
    if (count <= 0) {
      clearInterval(interval);
    } else {
      countEl.innerText = count; // নতুন নাম্বার দেখানো
    }
  }, 1000);

  // ৭ সেকেন্ড পরে সব hide করা
  setTimeout(() => {
    clearInterval(interval);      // নিরাপত্তার জন্য interval বন্ধ
    //text.style.display = "none";  // bottom-right টেক্সট hide
    countEl.style.display = "none"; // center নাম্বার hide
  }, 7000);    // ⬅️ 7 সেকেন্ড
}

